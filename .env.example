# ── Solen Backend — Variables de entorno ──────────────────────────
# Copiá este archivo a .env y completá los valores reales.

# Seguridad (cambiar en producción)
JWT_SECRET_KEY=genera_una_clave_segura_aqui_min_32_chars
DB_PASSWORD=solen_dev_pass
ENVIRONMENT=development

# Expo Push Notifications
# Obtener en: https://expo.dev/accounts/[tu-cuenta]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# Coach de IA (solen-protocols)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# URLs de producción (para deploy en Render)
# AUTH_URL=https://solen-auth.onrender.com
# PROTOCOLS_URL=https://solen-protocols.onrender.com
# ANALYTICS_URL=https://solen-analytics.onrender.com
# NOTIFY_URL=https://solen-notify.onrender.com
